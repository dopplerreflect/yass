{
	"name": "yass",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "yarn dlx -p prettier@~3.6.0 prettier --write .",
		"lint": "yarn dlx -p prettier@~3.6.0 prettier --check .",
		"render": "sh -c 'CHANGEID=\"$(jj --color=never show -s | grep Change | cut -d\" \" -f 3)\"; magick static/drawings/svg/\"$0\".svg -set comment \"CHANGE ID $CHANGEID\" ~/Pictures/\"$0\"-\"$CHANGEID\".png'"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.3",
		"@types/bun": "^1.3.14",
		"@types/chroma-js": "^3.1.2",
		"@types/seedrandom": "^3.0.8",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.3.3",
		"typescript": "^7.0.2",
		"vite": "^8.1.5"
	},
	"dependencies": {
		"@dopplerreflect/geometry": "^0.0.13",
		"@types/d3": "^7.4.3",
		"chroma-js": "^3.2.0",
		"d3": "^7.9.0",
		"geometric": "^3.0.9",
		"seedrandom": "^3.0.5",
		"spectral.js": "^3.0.0"
	},
	"packageManager": "yarn@4.17.1",
	"resolutions": {
		"@dopplerreflect/geometry": "portal:/home/doppler/Code/geometry"
	}
}
